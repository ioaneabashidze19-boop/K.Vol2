# ==============================================================================
# KavShare Environment Variables Template (.env.example)
# Copy this file to '.env.local' to configure your local development environment.
# Note: NEVER commit '.env.local' with real secrets to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# App Core Settings
# ------------------------------------------------------------------------------
# The primary base URL of your application. Used for links in emails and webhooks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Supabase Configuration
# Required for database connection, file storage, and shared link storage.
# ------------------------------------------------------------------------------
# The public API URL of your Supabase project (client & server safe).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# The public anonymous key for authentication and database calls (client & server safe).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# The private Service Role Key for elevated database bypass checks (SERVER SIDE ONLY).
# WARNING: Keep this secret; it bypasses Row Level Security (RLS) policies.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------------------------
# Clerk Authentication Configuration
# Required for user profiles, session states, and authentication gates.
# ------------------------------------------------------------------------------
# The public publishable key for your Clerk application instance (client & server safe).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# The private API secret key for Clerk administrative queries (SERVER SIDE ONLY).
CLERK_SECRET_KEY=sk_test_...

# The relative paths for user authentication redirect states in Next.js App Router.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ------------------------------------------------------------------------------
# Stripe Payments Configuration
# Required for processing subscription tiers, bandwidth packages, and payments.
# ------------------------------------------------------------------------------
# The public Stripe API key used to instantiate Stripe Elements (client & server safe).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# The private Stripe secret key for backend billing subscriptions (SERVER SIDE ONLY).
STRIPE_SECRET_KEY=sk_test_...

# The webhook signature secret from Stripe Dashboard to verify incoming events.
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------------------------
# Google Gemini AI API Configuration
# Used for smart classification of shared items and metadata generation.
# ------------------------------------------------------------------------------
# Your API key for Google Gemini generative AI models.
GOOGLE_API_KEY=your-google-gemini-api-key

# ------------------------------------------------------------------------------
# Groq AI API Configuration
# Used for ultra-low latency translations or LLM processing.
# ------------------------------------------------------------------------------
# The secret API key generated in the Groq Console.
GROQ_API_KEY=gsk_...

# ------------------------------------------------------------------------------
# Resend Email Configuration
# Required for file share link delivery, email reports, and security alerts.
# ------------------------------------------------------------------------------
# The API key generated from the Resend Dashboard.
RESEND_API_KEY=re_...

# The sender address that has been domain-verified on Resend.
RESEND_FROM_EMAIL=KavShare <noreply@yourdomain.com>

# ------------------------------------------------------------------------------
# Tally.so Webhooks
# Used for handling feedback, user surveys, or customer support ingestion.
# ------------------------------------------------------------------------------
# Secret signature key used to verify that webhook calls originate from Tally.so.
TALLY_WEBHOOK_SECRET=tally_secret_...
