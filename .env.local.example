# KavShare Environment Variables Template
# Copy this file to .env.local and populate with your credentials.

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Credentials (Public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Credentials (Private - Server Side Only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# File Storage Configuration
NEXT_PUBLIC_MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=image/*,application/pdf,application/zip,text/plain
